#!/bin/sh
# Removes Cursor attribution lines from commit messages (local hook).
COMMIT_MSG_FILE=$1
[ -f "$COMMIT_MSG_FILE" ] || exit 0

grep -v -E -i '(cursoragent@cursor\.com|Co-authored-by: Cursor|Made-with: Cursor)' "$COMMIT_MSG_FILE" > "$COMMIT_MSG_FILE.tmp" &&
  mv "$COMMIT_MSG_FILE.tmp" "$COMMIT_MSG_FILE"

exit 0
